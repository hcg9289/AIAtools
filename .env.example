# OpenRouter API Key. Do not commit a real key.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Text and vision crop models
FRONTEND_SLIDES_TEXT_MODEL=google/gemini-3.1-flash-lite
FRONTEND_SLIDES_VISION_MODEL=google/gemini-3.1-flash-lite
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Runtime
PORT=5008
CHROME_EXECUTABLE_PATH=/usr/bin/chromium
VAULT_AUTH_URL=http://wa-vault-1006:5001/api/v1/token/validate
